#!/bin/bash
# RedisManager — control script for per-user Redis instances
# /opt/redismanager/bin/redismanager-ctl
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
CONF_FILE="${SCRIPT_DIR}/etc/redismanager.conf"
TEMPLATE_FILE="${SCRIPT_DIR}/templates/redis-user.conf.tmpl"
SYSTEMD_TEMPLATE="${SCRIPT_DIR}/templates/redis-managed.service"
SYSTEMD_UNIT="/etc/systemd/system/redis-managed@.service"
LOCK_FILE="/var/run/redismanager-state.lock"
LEGACY_REDIS_DIR=".redis-managed"
ISOLATED_REDIS_DIR=".clwpos/redismanager"

# Load configuration
if [[ ! -f "$CONF_FILE" ]]; then
    echo "ERROR: Config file not found: $CONF_FILE" >&2
    exit 1
fi
# shellcheck source=/dev/null
source "$CONF_FILE"

# Ensure state directory exists
STATE_DIR="$(dirname "$STATE_FILE")"
mkdir -p "$STATE_DIR" "$LOG_DIR"

# Initialize state file if missing
if [[ ! -f "$STATE_FILE" ]]; then
    echo '{}' > "$STATE_FILE"
fi

# --- Username validation ---
# cPanel usernames: lowercase, starts with letter, max 16 chars on most setups,
# we allow up to 30 for flexibility. Same regex the WHM CGI uses.
VALID_USER_RE='^[a-z][a-z0-9_]{0,30}$'

validate_username_format() {
    local user="$1"
    if [[ ! "$user" =~ $VALID_USER_RE ]]; then
        echo "ERROR: Invalid username format '$user'. Must match: $VALID_USER_RE" >&2
        exit 1
    fi
}

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "${LOG_DIR}/redismanager.log"
}

usage() {
    cat <<EOF
Usage: $(basename "$0") <command> [arguments]

Commands:
  enable  <username> [memory_mb]  Enable Redis for a cPanel user
  disable <username>              Disable Redis and clean up
  restart <username>              Restart a user's Redis instance
  status  <username>              Show status of a user's Redis instance
  flush   <username>              Flush all data from a user's Redis
  list                            List all managed users with status
  info                            Show global resource usage
  set-memory <username> <mb>      Change memory limit for a user
  set-maxclients <username> <n>   Change max connections for a user
  list-binaries                   List detected Redis/Valkey server binaries
  apply-binary <path>             Switch binary, rewrite systemd unit, restart managed instances
  render-unit                     Render redis-managed@.service from current config
  launch  <username>              Internal: start a user's Redis instance

EOF
    exit 1
}

# --- State management ---
# All state operations use flock to prevent concurrent corruption.
# The state file (state.json) is shared between CLI, WHM CGI, cron, and hooks.

state_get() {
    local user="$1"
    flock -s "$LOCK_FILE" python3 -c "
import json, sys
with open('$STATE_FILE') as f:
    state = json.load(f)
u = state.get('$user', {})
if u:
    print(f\"memory={u.get('memory_mb', $DEFAULT_MEMORY_MB)}\")
    print(f\"maxclients={u.get('maxclients', $DEFAULT_MAXCLIENTS)}\")
    print(f\"enabled_at={u.get('enabled_at', 'unknown')}\")
    if u.get('redis_dir'):
        print(f\"redis_dir={u.get('redis_dir')}\")
else:
    sys.exit(1)
" 2>/dev/null
}

state_set() {
    local user="$1" memory_mb="$2" maxclients="${3:-$DEFAULT_MAXCLIENTS}" redis_dir="${4:-}"
    flock "$LOCK_FILE" python3 - "$STATE_FILE" "$user" "$memory_mb" "$maxclients" "$redis_dir" <<'PY'
import json, os, tempfile
from datetime import datetime
import sys

state_path, user, memory_mb, maxclients, redis_dir = sys.argv[1:6]
with open(state_path) as f:
    state = json.load(f)
existing = state.get(user, {})
state[user] = {
    'memory_mb': int(memory_mb),
    'maxclients': int(maxclients),
    'enabled_at': existing.get('enabled_at', datetime.now().isoformat())
}
if redis_dir:
    state[user]['redis_dir'] = redis_dir
elif existing.get('redis_dir'):
    state[user]['redis_dir'] = existing['redis_dir']
# Atomic write: temp file + rename avoids partial writes
fd, tmp = tempfile.mkstemp(dir=os.path.dirname(state_path))
with os.fdopen(fd, 'w') as f:
    json.dump(state, f, indent=2)
os.chmod(tmp, 0o644)
os.replace(tmp, state_path)
PY
}

state_remove() {
    local user="$1"
    flock "$LOCK_FILE" python3 -c "
import json, os, tempfile
with open('$STATE_FILE') as f:
    state = json.load(f)
state.pop('$user', None)
fd, tmp = tempfile.mkstemp(dir=os.path.dirname('$STATE_FILE'))
with os.fdopen(fd, 'w') as f:
    json.dump(state, f, indent=2)
os.chmod(tmp, 0o644)
os.rename(tmp, '$STATE_FILE')
"
}

state_total_memory() {
    flock -s "$LOCK_FILE" python3 -c "
import json
with open('$STATE_FILE') as f:
    state = json.load(f)
total = sum(u.get('memory_mb', $DEFAULT_MEMORY_MB) for u in state.values())
print(total)
"
}

state_redis_dir() {
    local user="$1"
    local redis_dir=""
    eval "$(state_get "$user" 2>/dev/null)" || return 1
    if [[ -n "${redis_dir:-}" ]]; then
        printf '%s\n' "$redis_dir"
    fi
}

state_list_users() {
    flock -s "$LOCK_FILE" python3 -c "
import json
with open('$STATE_FILE') as f:
    state = json.load(f)
for user, data in sorted(state.items()):
    print(f\"{user} {data.get('memory_mb', $DEFAULT_MEMORY_MB)} {data.get('enabled_at', 'unknown')}\")
"
}

# --- Validation ---

validate_user() {
    local user="$1"
    validate_username_format "$user"
    if ! id "$user" &>/dev/null; then
        echo "ERROR: User '$user' does not exist" >&2
        exit 1
    fi
    if [[ ! -d "/home/$user" ]]; then
        echo "ERROR: Home directory /home/$user not found" >&2
        exit 1
    fi
}

validate_binary() {
    if [[ ! -x "$REDIS_BINARY" ]]; then
        echo "ERROR: Redis binary not found or not executable: $REDIS_BINARY" >&2
        echo "       Install alt-redis or update REDIS_BINARY in $CONF_FILE" >&2
        exit 1
    fi
}

guess_cli_for_binary() {
    local binary_path="$1"
    local bin_dir
    bin_dir="$(dirname "$binary_path")"
    local cli_candidates=()

    case "$(basename "$binary_path")" in
        valkey-server)
            cli_candidates+=("${bin_dir}/valkey-cli" "${bin_dir}/redis-cli")
            ;;
        redis-server)
            cli_candidates+=("${bin_dir}/redis-cli" "${bin_dir}/valkey-cli")
            ;;
        *)
            cli_candidates+=("${bin_dir}/redis-cli" "${bin_dir}/valkey-cli")
            ;;
    esac

    local candidate
    for candidate in "${cli_candidates[@]}"; do
        if [[ -x "$candidate" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

list_available_binaries() {
    local -a candidates=(
        /opt/alt/redis/bin/redis-server
        /opt/alt/valkey/bin/valkey-server
        /usr/bin/redis-server
        /usr/bin/valkey-server
        /usr/local/bin/redis-server
        /usr/local/bin/valkey-server
    )
    local detected
    detected=$(command -v redis-server 2>/dev/null || true)
    [[ -n "$detected" ]] && candidates+=("$detected")
    detected=$(command -v valkey-server 2>/dev/null || true)
    [[ -n "$detected" ]] && candidates+=("$detected")

    local -A seen=()
    local candidate version cli
    for candidate in "${candidates[@]}"; do
        [[ -x "$candidate" ]] || continue
        [[ -z "${seen[$candidate]+x}" ]] || continue
        seen["$candidate"]=1
        version=$("$candidate" --version 2>/dev/null | head -n1 | tr '\n' ' ' | sed 's/[[:space:]]\+$//')
        cli=$(guess_cli_for_binary "$candidate" || true)
        printf '%s\t%s\t%s\n' "$candidate" "${version:-unknown}" "${cli:-}"
    done
}

validate_memory_mb() {
    local memory_mb="$1"
    if [[ ! "$memory_mb" =~ ^[0-9]+$ ]] || [[ "$memory_mb" -lt 16 ]] || [[ "$memory_mb" -gt 1024 ]]; then
        echo "ERROR: memory_mb must be between 16 and 1024" >&2
        exit 1
    fi
}

site_isolation_enabled() {
    local user="$1"
    local output

    output="$("$CAGEFSCTL" --site-isolation-list "$user" 2>/dev/null || true)"
    [[ -n "$output" ]] || return 1

    if grep -Eq '^[[:space:]]*[A-Za-z0-9][A-Za-z0-9.-]*\.[A-Za-z]{2,}' <<<"$output"; then
        return 0
    fi

    return 1
}

desired_redis_dir() {
    local user="$1"
    if site_isolation_enabled "$user"; then
        printf '/home/%s/%s\n' "$user" "$ISOLATED_REDIS_DIR"
    else
        printf '/home/%s/%s\n' "$user" "$LEGACY_REDIS_DIR"
    fi
}

alternate_redis_dir() {
    local user="$1"
    local desired
    desired="$(desired_redis_dir "$user")"
    if [[ "$desired" == "/home/${user}/${LEGACY_REDIS_DIR}" ]]; then
        printf '/home/%s/%s\n' "$user" "$ISOLATED_REDIS_DIR"
    else
        printf '/home/%s/%s\n' "$user" "$LEGACY_REDIS_DIR"
    fi
}

current_redis_dir() {
    local user="$1"
    local desired alternate stored
    local desired_socket alternate_socket

    stored="$(state_redis_dir "$user" || true)"
    if [[ -n "$stored" ]]; then
        printf '%s\n' "$stored"
        return 0
    fi

    desired="$(desired_redis_dir "$user")"
    desired_socket="${desired}/${SOCKET_NAME}"
    alternate="$(alternate_redis_dir "$user")"
    alternate_socket="${alternate}/${SOCKET_NAME}"

    if [[ -S "$desired_socket" || -e "$desired_socket" ]]; then
        printf '%s\n' "$desired"
        return 0
    fi

    if [[ -S "$alternate_socket" || -e "$alternate_socket" ]]; then
        printf '%s\n' "$alternate"
        return 0
    fi

    if [[ -d "$desired" ]]; then
        printf '%s\n' "$desired"
        return 0
    fi

    if [[ -d "$alternate" ]]; then
        printf '%s\n' "$alternate"
        return 0
    fi

    printf '%s\n' "$desired"
}

current_redis_socket() {
    local user="$1"
    printf '%s/%s\n' "$(current_redis_dir "$user")" "$SOCKET_NAME"
}

ensure_redis_dir_layout() {
    local user="$1"
    local desired alternate
    desired="$(desired_redis_dir "$user")"
    alternate="$(alternate_redis_dir "$user")"

    mkdir -p "$desired"
    if [[ -d "$alternate" ]]; then
        local moved=0
        while IFS= read -r -d '' item; do
            [[ -e "$item" ]] || continue
            local base
            base="$(basename "$item")"
            [[ "$base" == "redis.conf" ]] && continue
            mv -f "$item" "$desired/"
            moved=1
        done < <(find "$alternate" -mindepth 1 -maxdepth 1 -print0 2>/dev/null || true)

        rmdir "$alternate" 2>/dev/null || true
        if [[ $moved -eq 1 ]]; then
            log "Migrated Redis runtime files for ${user} into $desired"
        fi
    fi

    chown -R "${user}:${user}" "$desired"
    chmod 750 "$desired"
}

check_budget() {
    local requested="$1"
    local current
    current=$(state_total_memory)
    local projected=$((current + requested))
    if [[ $projected -gt $TOTAL_BUDGET_MB ]]; then
        echo "ERROR: Memory budget exceeded. Current: ${current}MB, Requested: ${requested}MB, Budget: ${TOTAL_BUDGET_MB}MB" >&2
        exit 1
    fi
}

# --- Session locking ---
#
# Why: PHP's phpredis extension does NOT enable session locking by default.
# Without it, concurrent requests (common in Joomla admin AJAX) read the same
# session simultaneously, causing race conditions — symptoms include random 500
# errors, lost form data, and "poltergeist" behavior where settings appear to
# reset themselves.
#
# What we deploy: a .user.ini file in each document root with these settings:
#   redis.session.locking_enabled = 1   — serialize session access
#   redis.session.lock_retries = 300    — retry up to 300 times (3 sec total)
#   redis.session.lock_wait_time = 10000 — 10ms between retries
#
# Why .user.ini: on cPanel with PHP-FPM / LSAPI, per-directory .user.ini is
# the standard way to override PHP settings without touching the global php.ini
# or per-vhost configs managed by cPanel. It's re-read every
# user_ini.cache_ttl seconds (default 300).
#
# Cleanup: on disable, we remove only our marked block from .user.ini — if the
# file contained other settings, they are preserved.

USERINI_MARKER_BEGIN="; >>> RedisManager session locking — do not edit"
USERINI_MARKER_END="; <<< RedisManager"
USERINI_CONTENT="redis.session.locking_enabled = 1
redis.session.lock_retries = 300
redis.session.lock_wait_time = 10000"

deploy_session_locking() {
    local user="$1"
    local homedir="/home/${user}"

    # Find all document roots for this user (main + addon/sub domains)
    local docroots=()
    docroots+=("${homedir}/public_html")

    # Also check addon/subdomain docroots from cPanel userdata
    if [[ -d "/var/cpanel/userdata/${user}" ]]; then
        for f in "/var/cpanel/userdata/${user}"/*; do
            [[ -f "$f" ]] || continue
            [[ "$f" == *.cache ]] && continue
            [[ "$(basename "$f")" == "main" ]] && continue
            local dr
            dr=$(awk '/^documentroot:/ { print $2; exit }' "$f" 2>/dev/null)
            if [[ -n "$dr" && -d "$dr" && "$dr" != "${homedir}/public_html" ]]; then
                docroots+=("$dr")
            fi
        done
    fi

    for docroot in "${docroots[@]}"; do
        [[ -d "$docroot" ]] || continue
        local ini_file="${docroot}/.user.ini"

        # Skip if our block already exists
        if [[ -f "$ini_file" ]] && grep -qF "$USERINI_MARKER_BEGIN" "$ini_file" 2>/dev/null; then
            continue
        fi

        # Append our block
        {
            echo ""
            echo "$USERINI_MARKER_BEGIN"
            echo "$USERINI_CONTENT"
            echo "$USERINI_MARKER_END"
        } >> "$ini_file"

        chown "${user}:${user}" "$ini_file"
        chmod 644 "$ini_file"
        log "Deployed .user.ini session locking to ${docroot}"
    done
}

remove_session_locking() {
    local user="$1"
    local homedir="/home/${user}"

    # Find all .user.ini files with our marker
    while IFS= read -r ini_file; do
        [[ -f "$ini_file" ]] || continue

        # Remove our block (marker begin → marker end, inclusive)
        local tmp="${ini_file}.rmtmp"
        awk -v begin="$USERINI_MARKER_BEGIN" -v end="$USERINI_MARKER_END" '
            $0 == begin { skip=1; next }
            $0 == end   { skip=0; next }
            !skip { print }
        ' "$ini_file" > "$tmp"

        # Remove trailing blank lines
        sed -i -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$tmp" 2>/dev/null || true

        # If file is now empty (only whitespace), remove it; otherwise replace
        if [[ ! -s "$tmp" ]] || ! grep -qP '\S' "$tmp" 2>/dev/null; then
            rm -f "$ini_file" "$tmp"
            log "Removed empty .user.ini from $(dirname "$ini_file")"
        else
            mv "$tmp" "$ini_file"
            chown "${user}:${user}" "$ini_file"
            chmod 644 "$ini_file"
            log "Cleaned .user.ini session locking from $(dirname "$ini_file")"
        fi
    done < <(find "$homedir" -name ".user.ini" -exec grep -lF "$USERINI_MARKER_BEGIN" {} + 2>/dev/null || true)
}

# --- Helpers ---

regenerate_config() {
    local user="$1" redis_dir="$2" memory_mb="$3" mc="$4"
    local conf_file="${redis_dir}/redis.conf"

    mkdir -p "$redis_dir"
    sed -e "s|{{USERNAME}}|${user}|g" \
        -e "s|{{REDIS_DIR}}|${redis_dir}|g" \
        -e "s|{{MAXMEMORY}}|${memory_mb}|g" \
        -e "s|{{MAXCLIENTS}}|${mc}|g" \
        "$TEMPLATE_FILE" > "$conf_file"

    chown "${user}:${user}" "$conf_file"
    chmod 640 "$conf_file"
}

render_systemd_unit() {
    [[ -f "$SYSTEMD_TEMPLATE" ]] || {
        echo "ERROR: Systemd template not found: $SYSTEMD_TEMPLATE" >&2
        exit 1
    }

    local launcher="${SCRIPT_DIR}/bin/redismanager-ctl launch %i"

    python3 - "$SYSTEMD_TEMPLATE" "$SYSTEMD_UNIT" "$launcher" <<'PY'
import os
import sys
import tempfile

template_path, output_path, launcher = sys.argv[1:4]

with open(template_path, "r", encoding="utf-8") as fh:
    content = fh.read()

content = content.replace("{{LAUNCHER}}", launcher)

fd, tmp = tempfile.mkstemp(dir=os.path.dirname(output_path))
try:
    with os.fdopen(fd, "w", encoding="utf-8") as fh:
        fh.write(content)
    os.replace(tmp, output_path)
    os.chmod(output_path, 0o644)
finally:
    if os.path.exists(tmp):
        os.unlink(tmp)
PY
}

update_global_binary_config() {
    local new_binary="$1"
    local new_cli="$2"

    python3 - "$CONF_FILE" "$new_binary" "$new_cli" <<'PY'
import os
import sys
import tempfile

conf_path, new_binary, new_cli = sys.argv[1:4]
with open(conf_path, "r", encoding="utf-8") as fh:
    lines = fh.readlines()

found_binary = False
found_cli = False
for idx, line in enumerate(lines):
    if line.startswith("REDIS_BINARY="):
        lines[idx] = f'REDIS_BINARY="{new_binary}"\n'
        found_binary = True
    elif line.startswith("REDIS_CLI="):
        lines[idx] = f'REDIS_CLI="{new_cli}"\n'
        found_cli = True

if not found_binary:
    lines.append(f'REDIS_BINARY="{new_binary}"\n')
if not found_cli:
    lines.append(f'REDIS_CLI="{new_cli}"\n')

fd, tmp = tempfile.mkstemp(dir=os.path.dirname(conf_path))
try:
    with os.fdopen(fd, "w", encoding="utf-8") as fh:
        fh.writelines(lines)
    os.replace(tmp, conf_path)
finally:
    if os.path.exists(tmp):
        os.unlink(tmp)
PY
}

restart_managed_instances() {
    local restarted=0 failed=0
    local user
    while IFS=' ' read -r user _; do
        [[ -n "$user" ]] || continue
        if systemctl restart "redis-managed@${user}" 2>/dev/null; then
            restarted=$((restarted + 1))
        else
            failed=$((failed + 1))
            echo "WARN: Failed to restart redis-managed@${user}" >&2
        fi
    done < <(state_list_users)

    printf '%s %s\n' "$restarted" "$failed"
}

is_joomla_config() {
    local file="$1"
    [[ -f "$file" ]] || return 1
    grep -q "class Config" "$file" 2>/dev/null || return 1
    grep -q 'public \$dbtype' "$file" 2>/dev/null || return 1
}

switch_joomla_managed_redis() {
    local file="$1" user="$2"
    local desired_socket alternate_socket
    desired_socket="$(desired_redis_dir "$user")/${SOCKET_NAME}"
    alternate_socket="$(alternate_redis_dir "$user")/${SOCKET_NAME}"

    python3 - "$file" "$desired_socket" "$alternate_socket" <<'PY'
import os
import re
import shutil
import stat
import sys
import tempfile

path = sys.argv[1]
managed_sockets = {socket for socket in sys.argv[2:] if socket}
backup_path = path + ".redismanager.bak"

with open(path, "r", encoding="utf-8") as fh:
    original = fh.read()

line_ending = "\r\n" if "\r\n" in original else "\n"
original_stat = os.stat(path)

prop_re = re.compile(r"^(\s*public\s+\$([A-Za-z0-9_]+)\s*=\s*)(['\"])(.*?)(\3\s*;\s*)$", re.MULTILINE)
props = {m.group(2): m.group(4) for m in prop_re.finditer(original)}

cache_uses_managed = props.get("cache_handler", "").lower() == "redis" and props.get("redis_server_host", "") in managed_sockets
session_uses_managed = props.get("session_handler", "").lower() == "redis" and props.get("session_redis_server_host", "") in managed_sockets

if not cache_uses_managed and not session_uses_managed:
    print("unchanged")
    sys.exit(0)

updated = original

def replace_prop(content, key, value):
    pattern = re.compile(rf"^(\s*public\s+\${re.escape(key)}\s*=\s*)(['\"])(.*?)(\2\s*;\s*)$", re.MULTILINE)
    return pattern.sub(lambda m: f"{m.group(1)}{m.group(2)}{value}{m.group(4)}", content, count=1)

if cache_uses_managed:
    updated = replace_prop(updated, "cache_handler", "file")

if session_uses_managed:
    updated = replace_prop(updated, "session_handler", "database")

if updated == original:
    print("unchanged")
    sys.exit(0)

if not os.path.exists(backup_path):
    shutil.copy2(path, backup_path)

fd, tmp = tempfile.mkstemp(dir=os.path.dirname(path))
try:
    with os.fdopen(fd, "w", encoding="utf-8", newline="") as fh:
        fh.write(updated.replace("\r\n", "\n").replace("\n", line_ending))
    os.replace(tmp, path)
    os.chmod(path, stat.S_IMODE(original_stat.st_mode))
    try:
        os.chown(path, original_stat.st_uid, original_stat.st_gid)
    except PermissionError:
        pass
    print("updated")
finally:
    if os.path.exists(tmp):
        os.unlink(tmp)
PY
}

find_and_switch_joomla_configs() {
    local user="$1"
    local homedir="/home/${user}"
    local -a candidates=()
    local -A seen=()

    [[ -d "$homedir" ]] || return 0

    while IFS= read -r file; do
        [[ -n "$file" ]] || continue
        if [[ -z "${seen[$file]+x}" ]]; then
            candidates+=("$file")
            seen["$file"]=1
        fi
    done < <(find "$homedir" \
        \( -path "*/cache/*" -o -path "*/administrator/cache/*" -o -path "*/tmp/*" -o -path "*/logs/*" -o -path "*/.trash/*" -o -path "*/.snapshot/*" \) -prune \
        -o -type f -name "configuration.php" -print 2>/dev/null || true)

    local changed=0
    for file in "${candidates[@]}"; do
        is_joomla_config "$file" || continue
        local result
        if ! result=$(switch_joomla_managed_redis "$file" "$user"); then
            echo "ERROR: Failed to update Joomla configuration: $file" >&2
            exit 1
        fi
        if [[ "$result" == "updated" ]]; then
            changed=$((changed + 1))
            log "Switched Joomla Redis config to safe defaults in $file"
        fi
    done

    if [[ $changed -gt 0 ]]; then
        echo "Adjusted ${changed} Joomla configuration file(s) before disabling Redis."
    fi
}

# --- Commands ---

cmd_enable() {
    local user="$1"
    local memory_mb="${2:-$DEFAULT_MEMORY_MB}"

    validate_user "$user"
    validate_binary
    validate_memory_mb "$memory_mb"

    # Check if already enabled
    if state_get "$user" &>/dev/null; then
        echo "WARN: Redis already enabled for '$user'. Use 'restart' or 'set-memory'." >&2
        exit 1
    fi

    # Check budget
    check_budget "$memory_mb"

    local maxclients="${DEFAULT_MAXCLIENTS}"
    local redis_dir
    redis_dir="$(desired_redis_dir "$user")"

    # Generate config from template
    regenerate_config "$user" "$redis_dir" "$memory_mb" "$maxclients"

    # Enable and start systemd service
    systemctl enable "redis-managed@${user}" --quiet 2>/dev/null
    systemctl start "redis-managed@${user}"

    # Update state
    state_set "$user" "$memory_mb" "$maxclients"

    # Deploy .user.ini with Redis session locking for all document roots
    deploy_session_locking "$user"

    log "ENABLED Redis for user=$user memory=${memory_mb}MB"

    # Show connection info
    echo "Redis enabled for '$user'"
    echo ""
    echo "Joomla configuration:"
    echo "  Cache Handler:    Redis"
    echo "  Redis Host:       ${redis_dir}/redis.sock"
    echo "  Redis Port:       6379  (default, ignored when using socket)"
    echo "  Redis Database:   0  (cache)"
    echo ""
    echo "  Session Handler:  Redis"
    echo "  Session Host:     ${redis_dir}/redis.sock"
    echo "  Session Port:     6379  (default, ignored when using socket)"
    echo "  Session Database: 1  (sessions)"
}

cmd_disable() {
    local user="$1"
    validate_username_format "$user"

    if ! state_get "$user" &>/dev/null; then
        echo "ERROR: Redis not enabled for '$user'" >&2
        exit 1
    fi

    # If Joomla still points to this managed Redis socket, switch it first to
    # avoid leaving the site with 500s after the Redis instance disappears.
    find_and_switch_joomla_configs "$user"

    # Stop and disable systemd service (don't fail if not running)
    systemctl stop "redis-managed@${user}" 2>/dev/null || true
    systemctl disable "redis-managed@${user}" --quiet 2>/dev/null || true

    # Remove data directory
    local legacy_dir="/home/${user}/${LEGACY_REDIS_DIR}"
    local isolated_dir="/home/${user}/${ISOLATED_REDIS_DIR}"
    [[ -d "$legacy_dir" ]] && rm -rf "$legacy_dir"
    [[ -d "$isolated_dir" ]] && rm -rf "$isolated_dir"

    # Remove .user.ini session locking entries
    remove_session_locking "$user"

    # Update state
    state_remove "$user"

    log "DISABLED Redis for user=$user"
    echo "Redis disabled for '$user'"
}

cmd_restart() {
    local user="$1"
    validate_username_format "$user"

    if ! state_get "$user" &>/dev/null; then
        echo "ERROR: Redis not enabled for '$user'" >&2
        exit 1
    fi

    eval "$(state_get "$user")"
    local redis_dir="${redis_dir:-$(desired_redis_dir "$user")}"
    state_set "$user" "${memory:-$DEFAULT_MEMORY_MB}" "${maxclients:-$DEFAULT_MAXCLIENTS}" "$redis_dir"
    systemctl restart "redis-managed@${user}"
    log "RESTARTED Redis for user=$user"
    echo "Redis restarted for '$user'"
}

cmd_status() {
    local user="$1"
    validate_username_format "$user"
    local socket
    socket="$(current_redis_socket "$user")"

    echo "=== Redis Status for '$user' ==="

    # State info
    if state_get "$user" &>/dev/null; then
        eval "$(state_get "$user")"
        echo "State:      enabled"
        echo "Memory:     ${memory}MB"
        echo "Maxclients: ${maxclients}"
        echo "Enabled at: ${enabled_at}"
    else
        echo "State:      not managed"
        return
    fi

    # Systemd status
    if systemctl is-active --quiet "redis-managed@${user}" 2>/dev/null; then
        echo "Service:    active"
    else
        echo "Service:    inactive"
    fi

    # Socket check
    if [[ -S "$socket" ]]; then
        echo "Socket:     ${socket} (exists)"
    else
        echo "Socket:     ${socket} (MISSING)"
        return
    fi

    # Redis info via CLI
    if [[ -x "$REDIS_CLI" ]]; then
        local info
        info=$("$REDIS_CLI" -s "$socket" INFO memory 2>/dev/null | grep -E 'used_memory_human|maxmemory_human' || true)
        if [[ -n "$info" ]]; then
            echo ""
            echo "$info"
        fi
    fi
}

cmd_flush() {
    local user="$1"
    validate_username_format "$user"
    local socket
    socket="$(current_redis_socket "$user")"

    if [[ ! -S "$socket" ]]; then
        echo "ERROR: Socket not found: $socket" >&2
        exit 1
    fi

    "$REDIS_CLI" -s "$socket" FLUSHALL >/dev/null
    log "FLUSHED Redis for user=$user"
    echo "Redis flushed for '$user'"
}

cmd_set_memory() {
    local user="$1"
    local memory_mb="$2"

    if ! state_get "$user" &>/dev/null; then
        echo "ERROR: Redis not enabled for '$user'" >&2
        exit 1
    fi

    validate_user "$user"
    validate_memory_mb "$memory_mb"

    # Check budget (subtract current allocation, add new)
    eval "$(state_get "$user")"
    local current_alloc="${memory}"
    local current_maxclients="${maxclients:-$DEFAULT_MAXCLIENTS}"
    local current_redis_dir="${redis_dir:-}"
    local delta=$((memory_mb - current_alloc))
    if [[ $delta -gt 0 ]]; then
        check_budget "$delta"
    fi

    local redis_dir
    redis_dir="${current_redis_dir:-$(desired_redis_dir "$user")}"

    regenerate_config "$user" "$redis_dir" "$memory_mb" "$current_maxclients"

    # Update state and restart
    state_set "$user" "$memory_mb" "$current_maxclients" "$redis_dir"
    systemctl restart "redis-managed@${user}"

    log "SET-MEMORY Redis for user=$user to ${memory_mb}MB"
    echo "Memory limit for '$user' set to ${memory_mb}MB and restarted"
}

cmd_set_maxclients() {
    local user="$1"
    local new_maxclients="$2"

    if ! state_get "$user" &>/dev/null; then
        echo "ERROR: Redis not enabled for '$user'" >&2
        exit 1
    fi

    validate_user "$user"

    if [[ ! "$new_maxclients" =~ ^[0-9]+$ ]] || [[ "$new_maxclients" -lt 8 ]] || [[ "$new_maxclients" -gt 1024 ]]; then
        echo "ERROR: maxclients must be between 8 and 1024" >&2
        exit 1
    fi

    eval "$(state_get "$user")"
    local current_memory="${memory}"
    local current_redis_dir="${redis_dir:-}"

    local redis_dir
    redis_dir="${current_redis_dir:-$(desired_redis_dir "$user")}"

    regenerate_config "$user" "$redis_dir" "$current_memory" "$new_maxclients"

    # Update state and restart
    state_set "$user" "$current_memory" "$new_maxclients" "$redis_dir"
    systemctl restart "redis-managed@${user}"

    log "SET-MAXCLIENTS Redis for user=$user to ${new_maxclients}"
    echo "Max clients for '$user' set to ${new_maxclients} and restarted"
}

cmd_list() {
    local total_memory
    total_memory=$(state_total_memory)
    local count=0

    printf "%-20s %-8s %-10s %-8s %-20s %s\n" "USER" "MEMORY" "MAXCLIENT" "STATUS" "ENABLED AT" "SOCKET"
    printf "%-20s %-8s %-10s %-8s %-20s %s\n" "----" "------" "---------" "------" "----------" "------"

    while IFS=' ' read -r user mem enabled_at; do
        [[ -z "$user" ]] && continue
        count=$((count + 1))

        local status="inactive"
        if systemctl is-active --quiet "redis-managed@${user}" 2>/dev/null; then
            status="active"
        fi

        # Get maxclients from state
        local mc="$DEFAULT_MAXCLIENTS"
        if state_get "$user" &>/dev/null; then
            eval "$(state_get "$user")"
            mc="${maxclients:-$DEFAULT_MAXCLIENTS}"
        fi

        local socket
        socket="$(current_redis_socket "$user")"
        printf "%-20s %-8s %-10s %-8s %-20s %s\n" "$user" "${mem}MB" "$mc" "$status" "$enabled_at" "$socket"
    done < <(state_list_users)

    echo ""
    echo "Total: ${count} instances, ${total_memory}MB / ${TOTAL_BUDGET_MB}MB budget"
}

cmd_info() {
    local total_memory
    total_memory=$(state_total_memory)
    local count
    count=$(state_list_users | wc -l)

    echo "=== RedisManager Info ==="
    echo "Binary:       $REDIS_BINARY"
    if [[ -x "$REDIS_BINARY" ]]; then
        echo "Version:      $("$REDIS_BINARY" --version 2>/dev/null | awk '{print $3}' | cut -d= -f2)"
    else
        echo "Version:      BINARY NOT FOUND"
    fi
    echo "Instances:    ${count}"
    echo "Memory used:  ${total_memory}MB / ${TOTAL_BUDGET_MB}MB"
    echo "Maxclients:   $DEFAULT_MAXCLIENTS (default)"
    echo "State file:   $STATE_FILE"
    echo "CageFS:       $USE_CAGEFS"
    echo ""

    echo "=== Detected Binaries ==="
    if ! list_available_binaries; then
        echo "No Redis/Valkey server binaries detected"
    fi
    echo ""

    # Show system memory
    echo "=== System Memory ==="
    free -m | head -2
}

cmd_list_binaries() {
    list_available_binaries
}

cmd_render_unit() {
    validate_binary
    render_systemd_unit
    systemctl daemon-reload
    echo "Rendered ${SYSTEMD_UNIT} using ${REDIS_BINARY}"
}

cmd_launch() {
    local user="$1"
    validate_user "$user"
    validate_binary

    local memory_mb="$DEFAULT_MEMORY_MB"
    local maxclients="$DEFAULT_MAXCLIENTS"
    local redis_dir=""

    if state_get "$user" &>/dev/null; then
        eval "$(state_get "$user")"
        memory_mb="${memory:-$DEFAULT_MEMORY_MB}"
        maxclients="${maxclients:-$DEFAULT_MAXCLIENTS}"
        redis_dir="${redis_dir:-}"
    fi

    ensure_redis_dir_layout "$user"

    redis_dir="${redis_dir:-$(desired_redis_dir "$user")}"
    regenerate_config "$user" "$redis_dir" "$memory_mb" "$maxclients"

    if [[ "$USE_CAGEFS" == "true" ]]; then
        exec "$CAGEFS_ENTER" "$REDIS_BINARY" "$redis_dir/redis.conf"
    fi

    exec "$REDIS_BINARY" "$redis_dir/redis.conf"
}

cmd_apply_binary() {
    local new_binary="$1"
    local new_cli

    if [[ ! "$new_binary" =~ ^/[A-Za-z0-9._/+-]+$ ]]; then
        echo "ERROR: Invalid binary path: $new_binary" >&2
        exit 1
    fi
    if [[ ! -x "$new_binary" ]]; then
        echo "ERROR: Binary not found or not executable: $new_binary" >&2
        exit 1
    fi

    new_cli=$(guess_cli_for_binary "$new_binary" || true)
    if [[ -z "$new_cli" ]]; then
        echo "ERROR: Could not find a matching CLI binary for: $new_binary" >&2
        exit 1
    fi

    update_global_binary_config "$new_binary" "$new_cli"

    # Reload config for the current process before rendering/restarting.
    # shellcheck source=/dev/null
    source "$CONF_FILE"

    render_systemd_unit
    systemctl daemon-reload

    local restarted failed
    read -r restarted failed < <(restart_managed_instances)

    log "APPLIED binary change REDIS_BINARY=${new_binary} REDIS_CLI=${new_cli} restarted=${restarted} failed=${failed}"
    echo "Applied binary: ${new_binary}"
    echo "CLI binary:     ${new_cli}"
    echo "Restarted:      ${restarted}"
    echo "Failed:         ${failed}"
    [[ "$failed" -eq 0 ]]
}

# --- Main ---

if [[ $# -lt 1 ]]; then
    usage
fi

CMD="$1"
shift

case "$CMD" in
    enable)
        [[ $# -lt 1 ]] && { echo "Usage: $(basename "$0") enable <username> [memory_mb]"; exit 1; }
        cmd_enable "$@"
        ;;
    disable)
        [[ $# -lt 1 ]] && { echo "Usage: $(basename "$0") disable <username>"; exit 1; }
        cmd_disable "$@"
        ;;
    restart)
        [[ $# -lt 1 ]] && { echo "Usage: $(basename "$0") restart <username>"; exit 1; }
        cmd_restart "$@"
        ;;
    status)
        [[ $# -lt 1 ]] && { echo "Usage: $(basename "$0") status <username>"; exit 1; }
        cmd_status "$@"
        ;;
    flush)
        [[ $# -lt 1 ]] && { echo "Usage: $(basename "$0") flush <username>"; exit 1; }
        cmd_flush "$@"
        ;;
    list)
        cmd_list
        ;;
    info)
        cmd_info
        ;;
    set-memory)
        [[ $# -lt 2 ]] && { echo "Usage: $(basename "$0") set-memory <username> <mb>"; exit 1; }
        cmd_set_memory "$@"
        ;;
    set-maxclients)
        [[ $# -lt 2 ]] && { echo "Usage: $(basename "$0") set-maxclients <username> <n>"; exit 1; }
        cmd_set_maxclients "$@"
        ;;
    list-binaries)
        cmd_list_binaries
        ;;
    apply-binary)
        [[ $# -lt 1 ]] && { echo "Usage: $(basename "$0") apply-binary <path>"; exit 1; }
        cmd_apply_binary "$@"
        ;;
    render-unit)
        cmd_render_unit
        ;;
    launch)
        [[ $# -lt 1 ]] && { echo "Usage: $(basename "$0") launch <username>"; exit 1; }
        cmd_launch "$@"
        ;;
    *)
        echo "Unknown command: $CMD" >&2
        usage
        ;;
esac
